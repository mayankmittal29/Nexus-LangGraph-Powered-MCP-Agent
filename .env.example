# =============================================================================
# LangGraph MCP Chatbot — environment configuration
# Copy this file to `.env` and fill in the values you need.
# =============================================================================

# ---- LLM provider ----------------------------------------------------------
# Which LLM backend the graph should use: "openai" or "gemini"
LLM_PROVIDER=openai

# Required if LLM_PROVIDER=openai (read automatically by langchain-openai)
OPENAI_API_KEY=your_openai_api_key_here

# Required if LLM_PROVIDER=gemini (read automatically by langchain-google-genai)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ---- Persistence ------------------------------------------------------------
# Path to the SQLite database used by the LangGraph checkpointer
CHECKPOINT_DB_PATH=chatbot.db

# ---- Tools --------------------------------------------------------------
# DuckDuckGo search tool region
DUCKDUCKGO_REGION=us-en

# Alpha Vantage API key, used by the get_stock_price tool
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ---- MCP servers -------------------------------------------------------------
# Local stdio MCP server (arithmetic tools)
MCP_ARITH_COMMAND=python3
MCP_ARITH_SERVER_PATH=/path/to/mcp-math-server/main.py

# Remote streamable-HTTP MCP server (expense tools)
MCP_EXPENSE_SERVER_URL=https://splendid-gold-dingo.fastmcp.app/mcp
